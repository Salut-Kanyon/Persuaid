# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# electron desktop build
/dist
.desktop-stash-api

# Local shortcuts into dist/ (keep README only)
/DesktopBuild/*
!/DesktopBuild/README.txt

# production (track macOS app icon in this folder)
/build/*
!/build/icon.icns

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# notarized DMG too large for GitHub (100MB limit); host via Releases or CDN
/public/downloads/*.dmg
Persuaid-0.1.0-arm64-signed.dmg

{
  "name": "persuaid",
  "productName": "Persuaid",
  "version": "0.1.0",
  "description": "Real-time AI sales copilot for live calls.",
  "author": "Persuaid <persuaidapp@gmail.com>",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "stt:proxy": "node scripts/stt-ws-proxy.js",
    "dev:stt": "concurrently -k -n next,stt -c blue,green \"next dev\" \"node scripts/stt-ws-proxy.js\"",
    "dev:web": "next dev",
    "build": "next build",
    "build:desktop": "node scripts/next-static-export-build.js",
    "start": "next start",
    "lint": "next lint",
    "desktop": "npm run build:desktop && electron .",
    "desktop:dev": "node scripts/run-desktop-dev.js",
    "desktop:dev:inspect": "cross-env ELECTRON_OPEN_DEVTOOLS=1 node scripts/run-desktop-dev.js",
    "clean:desktop": "node scripts/clean-desktop.js",
    "desktop:size": "node scripts/desktop-size.js",
    "desktop:artifact": "node -e \"const fs=require('fs');const path=require('path');const d='dist';const f=fs.existsSync(d)?fs.readdirSync(d).filter(x=>x.endsWith('.dmg')).sort().reverse()[0]:null;console.log(f?path.join(d,f):'');\"",
    "clean:out-downloads": "node scripts/clean-out-downloads.js",
    "clean:out-duplicates": "node scripts/clean-out-duplicates.js",
    "build:mac-icon": "bash scripts/build-macos-app-icon.sh",
    "dist": "npm run desktop:build",
    "desktop:build": "npm run build:mac-icon && npm run clean:desktop && npm run build:desktop && npm run clean:out-downloads && npm run clean:out-duplicates && electron-builder && node -e \"const fs=require('fs');const path=require('path');const distDir='dist';const dmgFiles=fs.readdirSync(distDir).filter(f=>f.endsWith('.dmg'));if(dmgFiles.length>0){const latest=dmgFiles.sort().reverse()[0];const src=path.join(distDir,latest);fs.copyFileSync(src,'public/downloads/Persuaid.dmg');fs.copyFileSync(src,'DesktopBuild/Persuaid.dmg');console.log('DMG copied to public/downloads/Persuaid.dmg and DesktopBuild/Persuaid.dmg');}else{console.log('No DMG file found in dist/');}\"",
    "pack": "npm run build:mac-icon && npm run clean:desktop && npm run build:desktop && npm run clean:out-downloads && npm run clean:out-duplicates && electron-builder --dir",
    "desktop:run": "dist/mac-arm64/Persuaid.app/Contents/MacOS/Persuaid",
    "desktop:logs": "./scripts/run-desktop-and-logs.sh"
  },
  "build": {
    "appId": "com.persuaid.app",
    "productName": "Persuaid",
    "publish": null,
    "asar": true,
    "afterSign": "scripts/notarize.js",
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "out",
        "to": "out"
      },
      {
        "from": "public/ElectrongPP.png",
        "to": "ElectrongPP.png"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Persuaid uses your microphone to transcribe calls and suggest what to say in real time."
      },
      "notarize": false,
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "gatekeeperAssess": false,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "sign": false
    },
    "win": {
      "icon": "public/ElectrongPP.png",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "public/ElectrongPP.png",
      "target": [
        "AppImage"
      ]
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "@vercel/analytics": "^2.0.0",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.5",
    "framer-motion": "^11.3.19",
    "next": "^14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.0",
    "stripe": "^14.14.0",
    "tailwind-merge": "^2.4.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.10",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.1.0",
    "cross-env": "^10.1.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.5",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.3",
    "wait-on": "^8.0.1"
  }
}

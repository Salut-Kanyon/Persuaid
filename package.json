{
  "name": "persuaid",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "stt:proxy": "node scripts/stt-ws-proxy.js",
    "dev:web": "next dev",
    "build": "next build",
    "build:desktop": "cross-env OUTPUT_STATIC=1 next build",
    "start": "next start",
    "lint": "next lint",
    "desktop": "npm run build:desktop && electron .",
    "desktop:dev": "concurrently -k -n dev,electron -c blue,green \"npm run dev\" \"wait-on http://localhost:3000 && cross-env DESKTOP_DEV=1 electron .\"",
    "clean:desktop": "node scripts/clean-desktop.js",
    "desktop:size": "node scripts/desktop-size.js",
    "desktop:artifact": "node -e \"const fs=require('fs');const path=require('path');const d='dist';const f=fs.existsSync(d)?fs.readdirSync(d).filter(x=>x.endsWith('.dmg')).sort().reverse()[0]:null;console.log(f?path.join(d,f):'');\"",
    "clean:out-downloads": "node scripts/clean-out-downloads.js",
    "clean:out-duplicates": "node scripts/clean-out-duplicates.js",
    "desktop:build": "npm run clean:desktop && npm run build:desktop && npm run clean:out-downloads && npm run clean:out-duplicates && electron-builder && node -e \"const fs=require('fs');const path=require('path');const distDir='dist';const dmgFiles=fs.readdirSync(distDir).filter(f=>f.endsWith('.dmg'));if(dmgFiles.length>0){const latest=dmgFiles.sort().reverse()[0];fs.copyFileSync(path.join(distDir,latest),'public/downloads/Persuaid.dmg');console.log('DMG copied to public/downloads/Persuaid.dmg');}else{console.log('No DMG file found in dist/');}\"",
    "pack": "npm run clean:desktop && npm run build:desktop && npm run clean:out-downloads && npm run clean:out-duplicates && electron-builder --dir",
    "desktop:run": "dist/mac-arm64/Persuaid.app/Contents/MacOS/Persuaid",
    "desktop:logs": "./scripts/run-desktop-and-logs.sh"
  },
  "build": {
    "appId": "com.persuaid.app",
    "productName": "Persuaid",
    "asar": true,
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "out",
        "to": "out"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "@vercel/analytics": "^2.0.0",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.5",
    "framer-motion": "^11.3.19",
    "next": "^14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.0",
    "stripe": "^14.14.0",
    "tailwind-merge": "^2.4.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.10",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.1.0",
    "cross-env": "^10.1.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.5",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.3",
    "wait-on": "^8.0.1"
  }
}
